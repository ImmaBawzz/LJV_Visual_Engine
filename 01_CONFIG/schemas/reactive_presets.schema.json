      "required": [
        "zoom_breath",
        "brightness_pulse",
        "vignette_pulse",
        "hook_lift",
        "climax_lift"
      ],
      "properties": {
        "zoom_breath": { "type": "number", "minimum": 0 },
        "brightness_pulse": { "type": "number", "minimum": 0 },
        "vignette_pulse": { "type": "number", "minimum": 0 },
        "hook_lift": { "type": "number", "minimum": 0 },
        "climax_lift": { "type": "number", "minimum": 0 }
      }
