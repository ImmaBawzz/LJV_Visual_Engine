# LJV Visual Engine - Environment Configuration
# Copy this file to .env and fill in your values

# === Core Authentication ===
# Secret key for session encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
LJV_SECRET_KEY=your-secret-key-32-chars-minimum

# Email address for initial admin account (single-admin mode)
LJV_DEVELOPER_EMAIL=admin@example.com

# === Session Configuration ===
# Session lifetime in minutes (default: 480 = 8 hours)
LJV_SESSION_LIFETIME_MINUTES=480

# Absolute timeout for sessions in minutes (default: 1440 = 24 hours)
LJV_SESSION_ABSOLUTE_TIMEOUT_MINUTES=1440

# Session cookie security (set to false only for local development)
LJV_SESSION_COOKIE_SECURE=true

# Re-authentication window for destructive actions in seconds (default: 300 = 5 minutes)
LJV_DESTRUCTIVE_ACTION_REAUTH_WINDOW_SEC=300

# === CORS Configuration ===
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://www.yourdomain.com
LJV_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# === Database Configuration ===
# Path to auth database (SQLite)
# Default: ./auth.db (relative to 05_SCRIPTS/dashboard/)
LJV_AUTH_DB_PATH=./auth.db

# === Rate Limiting ===
# Maximum auth attempts per window
LJV_AUTH_RATE_LIMIT_ATTEMPTS=5

# Rate limit window in seconds
LJV_AUTH_RATE_LIMIT_WINDOW_SEC=300

# === Google OAuth (Optional) ===
# Set to true only if you have Google OAuth configured
LJV_GOOGLE_OAUTH_ENABLED=false

# Google OAuth Client ID (from Google Cloud Console)
# Required only if LJV_GOOGLE_OAUTH_ENABLED=true
LJV_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret (from Google Cloud Console)
# Required only if LJV_GOOGLE_OAUTH_ENABLED=true
LJV_GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Debug Mode ===
# Set to true for development only, false for production
LJV_DEBUG=false

# === Squarespace Playwright Automation (Optional) ===
# Credentials are read only from local environment/.env and are never written by script logs.
SQ_USERNAME=
SQ_PASSWORD=

# Path for persisted authenticated browser session state.
# Reuse this to avoid repeated full logins; phone approval may still be required when session expires.
SQ_STORAGE_STATE_PATH=.playwright-squarespace-profile/storage-state.json

# Set true to force a clean login and regenerate session state.
SQ_FORCE_FRESH_LOGIN=false

# Optional browser channel (example: chrome, msedge)
SQ_BROWSER_CHANNEL=

# === Auth0 Playwright Automation (Optional) ===
# Auth0 application settings URL and application list URL.
AUTH0_APP_URL=https://manage.auth0.com/dashboard/us/dev-your-tenant-id/applications/your-client-id/settings
AUTH0_APPS_URL=https://manage.auth0.com/dashboard/us/dev-your-tenant-id/applications
AUTH0_APP_NAME=Your Application Name

# Optional login credentials for faster form entry; MFA approval remains manual.
AUTH0_USERNAME=
AUTH0_PASSWORD=

# Comma-separated values for Auth0 application settings fields.
AUTH0_ALLOWED_CALLBACKS=http://localhost:3000/auth/callback, https://vermanaut.com/auth/callback
AUTH0_ALLOWED_LOGOUTS=http://localhost:3000, https://vermanaut.com
AUTH0_ALLOWED_ORIGINS=http://localhost:3000, https://vermanaut.com

# Persisted browser session state for Auth0 dashboard automation.
AUTH0_STORAGE_STATE_PATH=.playwright-auth0-profile/storage-state.json
AUTH0_FORCE_FRESH_LOGIN=false
AUTH0_START_DELAY_MS=15000

# Optional browser channel (example: chrome, msedge)
AUTH0_BROWSER_CHANNEL=

# === Auth0 Management API Automation (Recommended) ===
# Use these to avoid interactive browser login and update/check settings directly via API.
AUTH0_DOMAIN=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Auth0 Application (Client) ID to update/check.
AUTH0_APP_CLIENT_ID=
